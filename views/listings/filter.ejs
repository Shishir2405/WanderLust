<% layout("layouts/boilerplate") -%>

<link rel="stylesheet" href="/css/index.css" />
<link rel="stylesheet" href="/css/filter-split.css" />

<style>
  .container {
    padding: 0;
  }

  @media only screen and (max-width: 470px) {
    .container {
      padding-inline: 0.75rem;
    }
  }

  @media only screen and (max-width: 700px) {
    #filter-near_search {
      display: inline-flex;
      border: 1.5px solid rgba(128, 128, 128, 0.507);
      border-radius: 50%;
      padding: 0.65rem;
      margin-inline: 0.25rem;
      cursor: pointer;
      color: black;
    }

    #filter-near_search i {
      font-weight: 900;
      font-size: 0.9rem;
    }
  }
</style>

<body>
  <% include("../includes/currency.ejs") %> <%-
  include("../includes/filters.ejs") %>

  <div class="tax-toggle toggler" style="margin-top: 1rem">
    <label class="form-check-label" for="flexSwitchCheckDefault"
      >Display total after taxes</label
    >
    <div class="form-check-reverse form-switch switch-container">
      <label class="switch">
        <input type="checkbox" role="switch" id="flexSwitch" />
        <span class="slider">
          <svg
            class="slider-icon"
            viewBox="0 0 32 32"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            role="presentation"
          >
            <path fill="none" d="m4 16.5 8 8 16-16"></path>
          </svg>
        </span>
      </label>
    </div>
  </div>

  <div class="split-view-toolbar">
    <button
      type="button"
      class="split-view-toolbar__toggle"
      data-split-view-toggle
      aria-pressed="false"
    >
      <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i>
      <span>Show map</span>
    </button>
  </div>

  <%
    const mappableListings = (listings || []).filter(function (l) {
      return l && l.geometry && Array.isArray(l.geometry.coordinates) && l.geometry.coordinates.length === 2;
    });
    const splitPayload = {
      mapToken: process.env.MAP_TOKEN || "",
      listings: mappableListings.map(function (l) {
        return {
          id: String(l._id),
          title: l.title,
          price: l.price,
          coordinates: l.geometry.coordinates,
        };
      })
    };
  %>
  <script id="filter-split-data" type="application/json"><%- JSON.stringify(splitPayload) %></script>

  <%
    function renderCard(listing, extraClass) {
      extraClass = extraClass || "";
  %>
    <a href="/listings/<%=listing._id%>" id="listing-link">
      <div
        class="card listing-card mt-3 <%= extraClass %>"
        data-title="<%=listing.title.toLowerCase()%>"
        data-listing-id="<%=listing._id%>"
        data-bedrooms="<%= listing.bedrooms %>"
        data-beds="<%= listing.beds %>"
        data-accessibility="<%= listing.locked %>"
        data-type="<%= listing.typeOfPlace %>"
      >
        <img
          src="<%=listing.image.url%>"
          class="card-img-top"
          alt="Listing Image"
          style="height: 18.75rem"
        />

        <form action="/wishlists/add" method="POST">
          <% if(currUser){ %>
          <input type="hidden" name="userId" value="<%= currUser._id %>" />
          <input type="hidden" name="listingId" value="<%= listing._id %>" />
          <button
            type="submit"
            id="submit-heart"
            style="background: none; border: none; padding: 0"
          >
            <p style="margin-right: 0.5rem; font-weight: 300">
              <% if (currUser &&
              currUser.favoriteListings.includes(listing._id)) { %>
              <i class="fa-solid fa-heart" style="color: #ff385c"></i>
              <% } else { %>
              <i class="fa-solid fa-heart" style="color: rgb(64, 64, 64)"></i>
              <% } %>
            </p>
          </button>
          <% } %>
        </form>

        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <b><%=listing.title %></b>
            <% const tier = (typeof priceTiers !== 'undefined' && priceTiers) ? priceTiers[String(listing._id)] : null; %>
            <% if (tier && tier.tier !== 'fair') { %>
              <span class="price-badge price-badge--<%= tier.tier %> price-badge--card">
                <% if (tier.tier === 'great-deal') { %>
                  <i class="fa-solid fa-bolt" aria-hidden="true"></i> <%= tier.delta %>% below avg
                <% } else { %>
                  <i class="fa-solid fa-crown" aria-hidden="true"></i> Premium
                <% } %>
              </span>
            <% } %>
            <br />
            <span
              class="price-without-gst"
              data-original-price="<%=listing.price%>"
              ><b> &#x20B9; <%=listing.price.toLocaleString("en-IN")%></b> /
              night</span
            >
            <span
              class="price-with-gst"
              style="display: none"
              data-original-price="<%=listing.price%>"
              ><b>
                &#x20B9; <%= (listing.price * 1.18).toLocaleString("en-IN")
                %></b
              >/ night</span
            >
          </p>
        </div>
      </div>
    </a>
  <% } %>

  <div class="filter-grid row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mb-4">
    <% for (let listing of listings) { renderCard(listing); } %>
  </div>

  <div class="filter-split" aria-hidden="true">
    <div class="filter-split__list row row-cols-xl-2 row-cols-lg-1 row-cols-md-1 row-cols-sm-1">
      <% for (let listing of listings) { renderCard(listing, "filter-split__card"); } %>
    </div>
    <div class="filter-split__map-wrap">
      <div class="filter-split__map" aria-label="Listings map"></div>
    </div>
  </div>
</body>

<script src="/JS/index.js"></script>
<script src="/JS/currency.js"></script>
<script src="/JS/filter-split.js"></script>
