<% layout("layouts/boilerplate") -%>

<link rel="stylesheet" href="/css/index.css" />
<link rel="stylesheet" href="/css/skeleton.css" />
<link rel="stylesheet" href="/css/card-carousel.css" />

<br />
<div class="tax-toggle toggler">
  <label class="form-check-label" for="flexSwitchCheckDefault"
    >Display total after taxes</label
  >
  <div class="form-check-reverse form-switch switch-container">
    <label class="switch">
      <input type="checkbox" role="switch" id="flexSwitch" />
      <span class="slider">
        <svg
          class="slider-icon"
          viewBox="0 0 32 32"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          role="presentation"
        >
          <path fill="none" d="m4 16.5 8 8 16-16"></path>
        </svg>
      </span>
    </label>
  </div>
</div>

<%- include("../includes/currency.ejs") %> <%-
include("../includes/filters.ejs") %>

<style>
  .container {
    padding: 0;
  }

  #heart{
   filter: drop-shadow(5px 5px 8px #ff2850);
  }
  .fa-solid {
    text-shadow: 0 0 2px white, 0 0 2px white, 0 0 2px white, 0 0 1px white;
  }
  @media only screen and (max-width: 470px) {
    .container {
      padding-inline: 0.75rem;
    }
  }

  @media only screen and (max-width: 700px) {
    #filter-near_search {
      display: inline-flex;
      border: 1.5px solid rgba(128, 128, 128, 0.507);
      border-radius: 50%;
      padding: 0.65rem;
      margin-inline: 0.25rem;
      cursor: pointer;
      color: black;
    }

    #filter-near_search i {
      font-weight: 900;
      font-size: 0.9rem;
    }
  }
</style>

<div
  class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mb-4"
  id="listing-container"
>
  <% for(let listing of allListings){ %>
  <a href="/listings/<%=listing._id%>" id="listing-link">
    <div
      class="card listing-card"
      data-title="<%=listing.title.toLowerCase()%>"
      data-listing-id="<%=listing._id%>"
      data-bedrooms="<%= listing.bedrooms %>"
      data-beds="<%= listing.beds %>"
      data-accessibility="<%= listing.locked %>"
      data-type="<%= listing.typeOfPlace %>"
    >
      <% if (listing.averageRating === 5) { %>
      <div class="favorite-tag">Guest favourite</div>
      <% } %>

      <%
        const slides = [listing.image].concat(listing.gallery || []).filter(s => s && s.url);
      %>
      <div class="card-carousel <%= slides.length <= 1 ? 'card-carousel--single' : '' %>">
        <div class="card-carousel__track">
          <% slides.forEach(function (slide, i) { %>
            <div class="card-carousel__slide">
              <div class="card-image-wrap is-loading" style="border-radius:0;">
                <img
                  src="<%= slide.url %>"
                  alt="Listing image <%= i + 1 %>"
                  loading="<%= i === 0 ? 'eager' : 'lazy' %>"
                />
              </div>
            </div>
          <% }) %>
        </div>
        <% if (slides.length > 1) { %>
          <button type="button" class="card-carousel__btn card-carousel__btn--prev" aria-label="Previous photo">
            <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
          </button>
          <button type="button" class="card-carousel__btn card-carousel__btn--next" aria-label="Next photo">
            <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
          </button>
          <div class="card-carousel__dots" aria-hidden="true">
            <% slides.forEach(function (_, i) { %>
              <button type="button" class="card-carousel__dot <%= i === 0 ? 'is-active' : '' %>" tabindex="-1"></button>
            <% }) %>
          </div>
        <% } %>
      </div>

      <form action="/wishlists/add" method="POST">
        <% if(currUser){ %>
        <input type="hidden" name="userId" value="<%= currUser._id %>" />
        <input type="hidden" name="listingId" value="<%= listing._id %>" />
        <button
          type="submit"
          id="submit-heart"
          style="background: none; border: none; padding: 0"
        >
          <p style="margin-right: 0.5rem; font-weight: 300">
            <% if (currUser && currUser.favoriteListings.includes(listing._id))
            { %>
            <i class="fa-solid fa-heart" style="color: #ff385c"  id="heart"></i>
            <!-- Filled heart -->
            <% } else { %>
            <i class="fa-solid fa-heart" style="color: rgba(64, 64, 64, 0.943)"></i>
            <!-- Empty heart -->
            <% } %>
          </p>
        </button>
        <% } else{ %> 
          <button
          type="submit"
          id="submit-heart"
          style="background: none; border: none; padding: 0"
        >
        <i class="fa-solid fa-heart" style="color: rgb(64, 64, 64)"></i>
          </p>
        </button> <% }%>
      </form>

      <div class="card-img-overlay"></div>
      <div class="card-body">
        <p class="card-text" style="margin-left: 0.25rem">
          <b><%=listing.title %></b>
          <% const tier = (typeof priceTiers !== 'undefined' && priceTiers) ? priceTiers[String(listing._id)] : null; %>
          <% if (tier && tier.tier !== 'fair') { %>
            <span class="price-badge price-badge--<%= tier.tier %> price-badge--card">
              <% if (tier.tier === 'great-deal') { %>
                <i class="fa-solid fa-bolt" aria-hidden="true"></i> <%= tier.delta %>% below avg
              <% } else { %>
                <i class="fa-solid fa-crown" aria-hidden="true"></i> Premium
              <% } %>
            </span>
          <% } %>
          <br />
          <span
            class="price-without-gst"
            data-original-price="<%=listing.price%>"
            ><b> &#x20B9; <%=listing.price.toLocaleString("en-IN")%></b> /
            night</span
          >
          <span
            class="price-with-gst"
            style="display: none"
            data-original-price="<%=listing.price%>"
            ><b>
              &#x20B9; <%= (listing.price * 1.18).toLocaleString("en-IN") %> </b
            >/ night
          </span>
        </p>
      </div>
    </div>
  </a>
  <% } %>
</div>

<script src="/JS/skeleton.js"></script>
<script src="/JS/card-carousel.js"></script>
<script src="/JS/index.js"></script>
<script src="/JS/currency.js"></script>
